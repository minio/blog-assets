        <JDBCSampler guiclass="TestBeanGUI" testclass="JDBCSampler" testname="Q50" enabled="true">
          <stringProp name="dataSource">jdbcConfig</stringProp>
          <stringProp name="query">SELECT
  s_store_name
, s_company_id
, s_street_number
, s_street_name
, s_street_type
, s_suite_number
, s_city
, s_county
, s_state
, s_zip
, sum((CASE WHEN ((sr_returned_date_sk - ss_sold_date_sk) &lt;= 30) THEN 1 ELSE 0 END)) date_30_days
, sum((CASE WHEN ((sr_returned_date_sk - ss_sold_date_sk) &gt; 30)
   AND ((sr_returned_date_sk - ss_sold_date_sk) &lt;= 60) THEN 1 ELSE 0 END)) date_31_60_days
, sum((CASE WHEN ((sr_returned_date_sk - ss_sold_date_sk) &gt; 60)
   AND ((sr_returned_date_sk - ss_sold_date_sk) &lt;= 90) THEN 1 ELSE 0 END)) date_61_90_days
, sum((CASE WHEN ((sr_returned_date_sk - ss_sold_date_sk) &gt; 90)
   AND ((sr_returned_date_sk - ss_sold_date_sk) &lt;= 120) THEN 1 ELSE 0 END)) date_91_120_days
, sum((CASE WHEN ((sr_returned_date_sk - ss_sold_date_sk) &gt; 120) THEN 1 ELSE 0 END)) date_greater_than_120_days
FROM
  store_sales
, store_returns
, store
, date_dim d1
, date_dim d2
WHERE (d2.d_year = 2001)
   AND (d2.d_moy = 8)
   AND (ss_ticket_number = sr_ticket_number)
   AND (ss_item_sk = sr_item_sk)
   AND (ss_sold_date_sk = d1.d_date_sk)
   AND (sr_returned_date_sk = d2.d_date_sk)
   AND (ss_customer_sk = sr_customer_sk)
   AND (ss_store_sk = s_store_sk)
GROUP BY s_store_name, s_company_id, s_street_number, s_street_name, s_street_type, s_suite_number, s_city, s_county, s_state, s_zip
HAVING (s_store_name IS NOT NULL)
   AND (s_company_id IS NOT NULL)
   AND (s_street_number IS NOT NULL)
   AND (s_street_name IS NOT NULL)
   AND (s_street_type IS NOT NULL)
   AND (s_city IS NOT NULL)
   AND (s_county IS NOT NULL)
   AND (s_state IS NOT NULL)
   AND (s_zip IS NOT NULL)
ORDER BY s_store_name ASC, s_company_id ASC, s_street_number ASC, s_street_name ASC, s_street_type ASC, s_suite_number ASC, s_city ASC, s_county ASC, s_state ASC, s_zip ASC
LIMIT 1000</stringProp>
