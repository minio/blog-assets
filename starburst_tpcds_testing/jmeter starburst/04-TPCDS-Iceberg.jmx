          <stringProp name="dataSource">jdbcConfig</stringProp>
          <stringProp name="query">SELECT
  i_brand_id brand_id
, i_brand brand
, sum(ss_ext_sales_price) ext_price
FROM
  date_dim
, store_sales
, item
WHERE (d_date_sk = ss_sold_date_sk)
   AND (ss_item_sk = i_item_sk)
   AND (i_manager_id = 28)
   AND (d_moy = 11)
