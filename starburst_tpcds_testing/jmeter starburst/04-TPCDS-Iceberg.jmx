        <JDBCSampler guiclass="TestBeanGUI" testclass="JDBCSampler" testname="Q20" enabled="true">
          <stringProp name="dataSource">jdbcConfig</stringProp>
          <stringProp name="query">SELECT
  i_item_id
, i_item_desc
, i_category
, i_class
, i_current_price
, sum(cs_ext_sales_price) itemrevenue
, ((sum(cs_ext_sales_price) * 100) / sum(sum(cs_ext_sales_price)) OVER (PARTITION BY i_class)) revenueratio
FROM
  catalog_sales
, item
, date_dim
WHERE (cs_item_sk = i_item_sk)
   AND (UPPER(i_category) IN (&apos;SPORTS&apos;, &apos;BOOKS&apos;, &apos;HOME&apos;))
   AND (cs_sold_date_sk = d_date_sk)
   AND (CAST(d_date AS DATE) BETWEEN CAST(&apos;1999-02-22&apos; AS DATE) AND (CAST(&apos;1999-02-22&apos; AS DATE) + INTERVAL  &apos;30&apos; DAY))
GROUP BY i_item_id, i_item_desc, i_category, i_class, i_current_price
HAVING (i_item_desc IS NOT NULL)
   AND (i_category IS NOT NULL)
   AND (i_class IS NOT NULL)
   AND (i_current_price IS NOT NULL)
ORDER BY i_category ASC, i_class ASC, i_item_id ASC, i_item_desc ASC, revenueratio ASC
LIMIT 1000</stringProp>
