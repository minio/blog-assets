GROUP BY ROLLUP (i_product_name, i_brand, i_class, i_category)
HAVING (i_product_name IS NOT NULL)
   AND (i_brand IS NOT NULL)
   AND (i_class IS NOT NULL)
   AND (i_category IS NOT NULL)
ORDER BY qoh ASC, i_product_name ASC, i_brand ASC, i_class ASC, i_category ASC
LIMIT 1000</stringProp>
