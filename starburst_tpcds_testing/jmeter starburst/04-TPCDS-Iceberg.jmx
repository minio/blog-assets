        <JDBCSampler guiclass="TestBeanGUI" testclass="JDBCSampler" testname="Q41" enabled="true">
          <stringProp name="dataSource">jdbcConfig</stringProp>
          <stringProp name="query">SELECT DISTINCT i_product_name
FROM
  item i1
WHERE (i_manufact_id BETWEEN 738 AND (738 + 40))
   AND ((
      SELECT count(*) item_cnt
      FROM
        item
      WHERE ((i_manufact = i1.i_manufact)
            AND (((UPPER(i_category) = &apos;WOMEN&apos;)
                  AND ((UPPER(i_color) = &apos;POWDER&apos;)
                     OR (UPPER(i_color) = &apos;KHAKI&apos;))
                  AND ((UPPER(i_units) = &apos;OUNCE&apos;)
                     OR (UPPER(i_units) = &apos;OZ&apos;))
                  AND ((UPPER(i_size) = &apos;MEDIUM&apos;)
                     OR (UPPER(i_size) = &apos;EXTRA LARGE&apos;)))
               OR ((UPPER(i_category) = &apos;WOMEN&apos;)
                  AND ((UPPER(i_color) = &apos;BROWN&apos;)
                     OR (UPPER(i_color) = &apos;HONEYDEW&apos;))
                  AND ((UPPER(i_units) = &apos;BUNC&apos;)
                     OR (UPPER(i_units) = &apos;TON&apos;))
                  AND ((UPPER(i_size) = &apos;N/A&apos;)
                     OR (UPPER(i_size) = &apos;SMALL&apos;)))
               OR ((UPPER(i_category) = &apos;MEN&apos;)
                  AND ((UPPER(i_color) = &apos;FLORAL&apos;)
                     OR (UPPER(i_color) = &apos;DEEP&apos;))
                  AND ((UPPER(i_units) = &apos;N/A&apos;)
                     OR (UPPER(i_units) = &apos;DOZEN&apos;))
                  AND ((UPPER(i_size) = &apos;PETITE&apos;)
                     OR (UPPER(i_size) = &apos;LARGE&apos;)))
               OR ((UPPER(i_category) = &apos;MEN&apos;)
                  AND ((UPPER(i_color) = &apos;LIGHT&apos;)
                     OR (UPPER(i_color) = &apos;CORNFLOWER&apos;))
                  AND ((UPPER(i_units) = &apos;BOX&apos;)
                     OR (UPPER(i_units) = &apos;POUND&apos;))
                  AND ((UPPER(i_size) = &apos;MEDIUM&apos;)
                     OR (UPPER(i_size) = &apos;EXTRA LARGE&apos;)))))
         OR ((i_manufact = i1.i_manufact)
            AND (((UPPER(i_category) = &apos;WOMEN&apos;)
                  AND ((UPPER(i_color) = &apos;MIDNIGHT&apos;)
                     OR (UPPER(i_color) = &apos;SNOW&apos;))
                  AND ((UPPER(i_units) = &apos;PALLET&apos;)
                     OR (UPPER(i_units) = &apos;GROSS&apos;))
                  AND ((UPPER(i_size) = &apos;MEDIUM&apos;)
                     OR (UPPER(i_size) = &apos;EXTRA LARGE&apos;)))
               OR ((UPPER(i_category) = &apos;WOMEN&apos;)
                  AND ((UPPER(i_color) = &apos;CYAN&apos;)
                     OR (UPPER(i_color) = &apos;PAPAYA&apos;))
                  AND ((UPPER(i_units) = &apos;CUP&apos;)
                     OR (UPPER(i_units) = &apos;DRAM&apos;))
                  AND ((UPPER(i_size) = &apos;N/A&apos;)
                     OR (UPPER(i_size) = &apos;SMALL&apos;)))
               OR ((UPPER(i_category) = &apos;MEN&apos;)
                  AND ((UPPER(i_color) = &apos;ORANGE&apos;)
                     OR (UPPER(i_color) = &apos;FROSTED&apos;))
                  AND ((UPPER(i_units) = &apos;EACH&apos;)
                     OR (UPPER(i_units) = &apos;TBL&apos;))
                  AND ((UPPER(i_size) = &apos;PETITE&apos;)
                     OR (UPPER(i_size) = &apos;LARGE&apos;)))
               OR ((UPPER(i_category) = &apos;MEN&apos;)
                  AND ((UPPER(i_color) = &apos;FOREST&apos;)
                     OR (UPPER(i_color) = &apos;GHOST&apos;))
                  AND ((UPPER(i_units) = &apos;LB&apos;)
                     OR (UPPER(i_units) = &apos;BUNDLE&apos;))
                  AND ((UPPER(i_size) = &apos;MEDIUM&apos;)
                     OR (UPPER(i_size) = &apos;EXTRA LARGE&apos;)))))
   ) &gt; 0)
ORDER BY i_product_name ASC
LIMIT 1000</stringProp>
