          <stringProp name="dataSource">jdbcConfig</stringProp>
          <stringProp name="query">SELECT
  i_item_id
, avg(cs_quantity) agg1
, avg(cs_list_price) agg2
, avg(cs_coupon_amt) agg3
, avg(cs_sales_price) agg4
FROM
