        <JDBCSampler guiclass="TestBeanGUI" testclass="JDBCSampler" testname="Q99" enabled="true">
          <stringProp name="dataSource">jdbcConfig</stringProp>
          <stringProp name="query">SELECT
  substr(w_warehouse_name, 1, 20)
, sm_type
, cc_name
, sum((CASE WHEN ((cs_ship_date_sk - cs_sold_date_sk) &lt;= 30) THEN 1 ELSE 0 END)) date_30_days
, sum((CASE WHEN ((cs_ship_date_sk - cs_sold_date_sk) &gt; 30)
   AND ((cs_ship_date_sk - cs_sold_date_sk) &lt;= 60) THEN 1 ELSE 0 END)) date_31_60_days
, sum((CASE WHEN ((cs_ship_date_sk - cs_sold_date_sk) &gt; 60)
   AND ((cs_ship_date_sk - cs_sold_date_sk) &lt;= 90) THEN 1 ELSE 0 END)) date_61_90_days
, sum((CASE WHEN ((cs_ship_date_sk - cs_sold_date_sk) &gt; 90)
   AND ((cs_ship_date_sk - cs_sold_date_sk) &lt;= 120) THEN 1 ELSE 0 END)) date_91_120_days
, sum((CASE WHEN ((cs_ship_date_sk - cs_sold_date_sk) &gt; 120) THEN 1 ELSE 0 END)) date_greater_than_120_days
FROM
  catalog_sales
, warehouse
, ship_mode
, call_center
, date_dim
WHERE (d_month_seq BETWEEN 1200 AND (1200 + 11))
   AND (cs_ship_date_sk = d_date_sk)
   AND (cs_warehouse_sk = w_warehouse_sk)
   AND (cs_ship_mode_sk = sm_ship_mode_sk)
   AND (cs_call_center_sk = cc_call_center_sk)
   AND (w_warehouse_name IS NOT NULL)
GROUP BY substr(w_warehouse_name, 1, 20), sm_type, cc_name
ORDER BY substr(w_warehouse_name, 1, 20) ASC, sm_type ASC, cc_name ASC
LIMIT 1000</stringProp>
