        <JDBCSampler guiclass="TestBeanGUI" testclass="JDBCSampler" testname="INSERT INTO date_dim" enabled="true">
          <stringProp name="dataSource">jdbcConfig</stringProp>
          <stringProp name="query">INSERT INTO date_dim
SELECT
	d_date_sk,
     TRIM(CAST(d_date_id AS varchar(16))) AS d_date_id,
     d_date,
     d_month_seq,
     d_week_seq,
