        <JDBCSampler guiclass="TestBeanGUI" testclass="JDBCSampler" testname="INSERT INTO customer" enabled="true">
          <stringProp name="dataSource">jdbcConfig</stringProp>
          <stringProp name="query">INSERT INTO customer
SELECT
	c_customer_sk,
     TRIM(CAST(c_customer_id AS varchar(16))) AS c_customer_id,
     c_current_cdemo_sk,
     c_current_hdemo_sk,
     c_current_addr_sk,
     c_first_shipto_date_sk,
     c_first_sales_date_sk,
     TRIM(CAST(c_salutation AS varchar(10))) AS c_salutation,
     TRIM(CAST(c_first_name AS varchar(20))) AS c_first_name,
     TRIM(CAST(c_last_name AS varchar(30))) AS c_last_name,
     TRIM(CAST(c_preferred_cust_flag AS varchar(1))) AS c_preferred_cust_flag,
     c_birth_day,
     c_birth_month,
     c_birth_year,
     c_birth_country,
     TRIM(CAST(c_login AS varchar(13))) AS c_login,
     TRIM(CAST(c_email_address AS varchar(50))) AS c_email_address,
     c_last_review_date_sk
FROM ${tpcds_connector}.${tpcds_schema}.customer</stringProp>
