     d_dow,
     d_moy,
     d_dom,
     d_qoy,
     d_fy_year,
     d_fy_quarter_seq,
     d_fy_week_seq,
     TRIM(CAST(d_day_name AS varchar(9))) AS d_day_name,
     TRIM(CAST(d_quarter_name AS varchar(6))) AS d_quarter_name,
     TRIM(CAST(d_holiday AS varchar(1))) AS d_holiday,
     TRIM(CAST(d_weekend AS varchar(1))) AS d_weekend,
     TRIM(CAST(d_following_holiday AS varchar(1))) AS d_following_holiday,
     d_first_dom,
     d_last_dom,
     d_same_day_ly,
     d_same_day_lq,
     TRIM(CAST(d_current_day AS varchar(1))) AS d_current_day,
     TRIM(CAST(d_current_week AS varchar(1))) AS d_current_week,
     TRIM(CAST(d_current_month AS varchar(1))) AS d_current_month,
     TRIM(CAST(d_current_quarter AS varchar(1))) AS d_current_quarter,
     TRIM(CAST(d_current_year AS varchar(1))) AS d_current_year
FROM ${tpcds_connector}.${tpcds_schema}.date_dim</stringProp>
